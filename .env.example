# Visa Fácil — Variables de entorno para desarrollo local (XAMPP)
# Copiar este archivo como .env y completar los valores

# ── Base de datos MySQL (XAMPP) ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visa_facil
DB_USER=root
DB_PASS=

# ── HubSpot CRM ──────────────────────────────────────────────
# Private App Token — se genera en HubSpot > Configuración > Integraciones > Aplicaciones privadas
HUBSPOT_TOKEN=pat-na1-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# ── Dapta (middleware de envío de correos) ───────────────────
DAPTA_WEBHOOK_URL=https://api.dapta.ai/api/9c9ae2b4d48889fa/envio-cotizaciones
DAPTA_API_KEY=
