# ── Base de datos (XAMPP / MySQL) ────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=visa_facil
DB_USER=visafacildev
DB_PASS=

# ── HubSpot ───────────────────────────────────────────────
# Token de acceso de la Private App → para llamar la API de HubSpot
# (obtener facturas, owners, propiedades personalizadas, etc.)
HUBSPOT_TOKEN=pat-nal-

# Secreto del cliente → valida la firma X-HubSpot-Signature de cada webhook entrante
# HubSpot → Settings → Integrations → Private Apps → [tu app] → Auth → Secreto del cliente
HUBSPOT_WEBHOOK_SECRET=

# ── Dapta (automatizaciones) ──────────────────────────────
DAPTA_WEBHOOK_URL=
DAPTA_API_KEY=
